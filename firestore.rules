rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Unconditional allow for sandbox editing to let any preview user edit and upload images
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Helpers
    function isValidSiteSettings(data) {
      return data.ministryName is string && data.ministryName.size() <= 200 &&
             data.prophetName is string && data.prophetName.size() <= 100 &&
             data.whatsapp is string && data.whatsapp.size() <= 50 &&
             data.email is string && data.email.size() <= 100;
    }

    function isValidPageSection(data) {
      return data.sectionId is string && data.sectionId.size() <= 100 &&
             data.title is string && data.title.size() <= 500 &&
             data.content is string && data.content.size() <= 10000 &&
             data.order is number;
    }

    function isValidGivingSystem(data) {
      return data.options is list && data.options.size() <= 20;
    }

    function isValidPrayerRequest(data) {
      return data.request is string && data.request.size() <= 2000 &&
             data.isAnonymous is bool &&
             data.status in ['pending', 'prayed', 'archived'];
    }

    function isValidStream(data) {
      return data.streamId is string && data.platform in ['youtube', 'vimeo'] && data.isLive is bool;
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.date is string && data.date.size() <= 50 &&
             data.time is string && data.time.size() <= 50 &&
             data.location is string && data.location.size() <= 200 &&
             data.category is string && data.category.size() <= 50 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 4000000));
    }

    function isValidSermon(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.speaker is string && data.speaker.size() <= 100 &&
             data.date is string && data.date.size() <= 50 &&
             data.audioUrl is string && data.audioUrl.size() <= 1000 &&
             data.description is string && data.description.size() <= 2000 &&
             data.category is string && data.category.size() <= 100 &&
             (!('duration' in data) || (data.duration is string && data.duration.size() <= 50));
    }

    function isValidExcerpt(data) {
      return data.text is string && data.text.size() <= 2000 &&
             data.source is string && data.source.size() <= 200 &&
             (!('category' in data) || (data.category is string && data.category.size() <= 100)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 4000000));
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() <= 300 &&
             data.content is string && data.content.size() <= 50000 &&
             data.author is string && data.author.size() <= 100 &&
             data.date is string && data.date.size() <= 50 &&
             (!('category' in data) || (data.category is string && data.category.size() <= 100)) &&
             (!('summary' in data) || (data.summary is string && data.summary.size() <= 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 4000000));
    }

    // Rules
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteSettings(request.resource.data);
    }

    match /settings/giving {
      allow read: if true;
      allow write: if isAdmin() && isValidGivingSystem(request.resource.data);
    }

    match /settings/stream {
      allow read: if true;
      allow write: if isAdmin() && isValidStream(request.resource.data);
    }

    match /sections/{sectionId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(sectionId) && isValidPageSection(request.resource.data);
      allow delete: if isAdmin();
    }

    match /prayerRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if isValidId(requestId) && isValidPrayerRequest(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(eventId) && isValidEvent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sermons/{sermonId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(sermonId) && isValidSermon(request.resource.data);
      allow delete: if isAdmin();
    }

    match /excerpts/{excerptId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(excerptId) && isValidExcerpt(request.resource.data);
      allow delete: if isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(postId) && isValidBlogPost(request.resource.data);
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable via console or higher privileges
    }
  }
}
